# Synapse homeserver config
# Copy this to homeserver.yaml and replace all CHANGE_ME values.
#
# Generate secrets with:
#   python3 -c "import secrets; print(secrets.token_hex(64))"

server_name: "YOUR_DOMAIN"
public_baseurl: "https://YOUR_DOMAIN"

# Listener: HTTP only, SSL terminated by your reverse proxy
listeners:
  - port: 8008
    tls: false
    type: http
    x_forwarded: true
    resources:
      - names: [client, federation]
        compress: false

# Database: PostgreSQL
database:
  name: psycopg2
  args:
    user: synapse
    password: CHANGE_ME_match_POSTGRES_PASSWORD
    database: synapse
    host: postgres
    port: 5432
    cp_min: 5
    cp_max: 10

# Media storage
media_store_path: /data/media_store
max_upload_size: 50M

# Logging
log_config: /data/log.config

# Security -- generate unique values for each:
macaroon_secret_key: "CHANGE_ME_generate_a_random_secret_key_here"
form_secret: "CHANGE_ME_generate_another_random_secret_here"
signing_key_path: /data/YOUR_DOMAIN.signing.key
registration_shared_secret: "CHANGE_ME_generate_a_third_random_secret_here"

# Registration — set to false after creating your accounts
enable_registration: false

# Disable federation for private local server
federation_domain_whitelist: []

# Trusted key servers (used for E2EE verification)
trusted_key_servers:
  - server_name: "matrix.org"

# Rate limiting — relaxed for private server
rc_message:
  per_second: 10
  burst_count: 20

rc_login:
  address:
    per_second: 5
    burst_count: 10
  account:
    per_second: 5
    burst_count: 10
  failed_attempts:
    per_second: 5
    burst_count: 10

# Suppress email requirements
email: {}

# Telemetry
report_stats: false
